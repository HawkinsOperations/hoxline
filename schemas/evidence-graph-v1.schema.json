{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hawkinsoperations.dev/hoxline/schemas/evidence-graph-v1.schema.json",
  "title": "Hoxline Evidence Graph v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "graph_id", "detection_id", "artifact_id", "nodes", "edges", "missing_evidence"],
  "properties": {
    "schema_version": { "const": "evidence-graph-v1" },
    "graph_id": { "type": "string" },
    "detection_id": { "type": "string" },
    "artifact_id": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "owner", "status"],
        "properties": {
          "type": {
            "enum": ["artifact_intake", "evidence_graph", "telemetry_contract_check", "controlled_validation", "runtime_candidate_ledger", "signal_observation", "human_review_gate", "proofcard", "claim_authority", "safe_blocked_claim"]
          }
        }
      }
    },
    "edges": { "type": "array" },
    "missing_evidence": { "type": "array", "items": { "type": "string" } }
  }
}
