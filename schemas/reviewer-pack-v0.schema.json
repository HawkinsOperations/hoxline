  "properties": {
    "schema_version": { "const": "proofcard-v1" },
    "artifact_id": { "const": "HO-DET-010" },
    "public_safe_status": { "const": "NOT_PUBLIC_SAFE" },
    "human_review_required": { "const": true },
    "ai_disposition_authority": { "const": false }
  }
}
