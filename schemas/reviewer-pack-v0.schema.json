{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hawkinsoperations.dev/hoxline/schemas/reviewer-pack-v0.schema.json",
  "title": "Hoxline Reviewer Pack v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "artifact_id",
    "proof_ceiling",
    "public_safe_status",
    "human_review_required",
    "ai_disposition_authority",
    "allowed_claims",
