{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hawkinsoperations.dev/hoxline/schemas/proofcard-v0.schema.json",
  "title": "Hoxline ProofCard v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proofcard_id",
    "artifact_id",
    "title",
    "proof_ceiling",
    "what_exists",
    "what_was_tested",
    "validation_result",
    "failed_or_blocked",
    "required_telemetry",
    "runtime_state",
    "signal_state",
    "human_review_state",
    "allowed_claims",
    "blocked_claims",
    "public_safe"
  ],
  "properties": {
    "schema_version": {
      "const": "proofcard-v0"
    },
    "proofcard_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "proof_ceiling": {
      "const": "CONTROLLED_VALIDATION_PRODUCT_DEMO_ONLY"
    },
    "what_exists": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "what_was_tested": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "validation_result": {
      "type": "object",
      "required": [
        "status",
        "deterministic",
        "scope"
      ]
    },
    "failed_or_blocked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "required_telemetry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "runtime_state": {
      "type": "object",
      "required": [
        "state",
        "observed",
        "evidence_refs"
      ]
    },
    "signal_state": {
      "type": "object",
      "required": [
        "state",
        "observed",
        "evidence_refs"
      ]
    },
    "human_review_state": {
      "type": "object",
      "required": [
        "status",
        "final_authorization",
        "review_refs"
      ]
    },
    "allowed_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "blocked_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim",
          "reason"
        ]
      }
    },
    "public_safe": {
      "const": false
    }
  }
}
